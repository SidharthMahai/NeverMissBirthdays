# Frontend -> Vercel API proxy
# Optional for local dev only. In production, frontend uses same-origin /api automatically.
VITE_API_BASE_URL=

# Vercel serverless function -> Apps Script
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
# Must match HARDCODED_CLIENT_KEY in apps-script/Code.gs
APPS_SCRIPT_CLIENT_KEY=replace-with-random-string
